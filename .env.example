# ========================================
# 林妹妹 Agent v2.0 环境变量配置
# cp .env.example .env && nano .env
# ========================================

# ---- 飞书企业应用（必填）----
# 申请：https://open.feishu.cn → 创建企业应用
FEISHU_APP_ID=cli_axxxxxxxxxxxx
FEISHU_APP_SECRET=QhkMpxxxxxxxxxxxxxxxxxxxx

# ---- 搜索 API（金融投研需要）----
# Tavily（申请：https://tavily.com）支持多 Key 逗号分隔轮询
TAVILY_KEYS=tvly-dev-xxx

# Brave（申请：https://brave.com/search/api）
BRAVE_KEYS=BSAxxx

# ---- MiniMax（可选）----
MINIMAX_API_KEY=

# ---- 数据加密（必填）----
# 生成密钥：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- 调试模式 ----
# DEBUG=true
