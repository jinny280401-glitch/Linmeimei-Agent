# ========================================
# 林妹妹 Agent 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ========================================

# Tavily 搜索 API（申请：https://tavily.com）
# 支持多 Key 轮询，逗号分隔：key1,key2,key3
TAVILY_KEYS=tvly-dev-xxx

# Brave 搜索 API（申请：https://brave.com/search/api）
# 支持多 Key 轮询，逗号分隔：key1,key2
BRAVE_KEYS=BSAxxx

# cc-connect 微信 Token（运行 cc-connect weixin setup 后自动生成）
CC_WEIXIN_TOKEN=

# OpenClaw（可选，使用 QClaw 时需要）
QCLAW_GATEWAY_TOKEN=
QCLAW_LLM_API_KEY=
QCLAW_LLM_BASE_URL=
